@prefix : <https://w3id.org/semts/vocabulary/scenario-knowledge#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix semts: <https://w3id.org/semts/ontology#> .
@base <https://w3id.org/semts/vocabulary/scenario-knowledge#> .

#################################################################
#    Properties
#################################################################

skos:definition rdf:type owl:AnnotationProperty .

skos:member rdf:type owl:ObjectProperty .

skos:prefLabel rdf:type owl:AnnotationProperty .

skos:broader rdf:type owl:ObjectProperty .

skos:narrower rdf:type owl:ObjectProperty .


#################################################################
#    Classes & Reasoning
#################################################################

skos:Collection rdf:type owl:Class .

skos:Concept rdf:type owl:Class .

semts:KnowledgeConcept rdf:type owl:Class ;
  rdfs:subClassOf [
    rdf:type owl:Class ;
    owl:unionOf (skos:Concept skos:Collection)
  ] .

skos:broader owl:inverseOf skos:narrower .
skos:narrower rdfs:subPropertyOf skos:narrowerTransitive .
skos:narrowerTransitive a owl:TransitiveProperty .

skos:member owl:propertyChainAxiom ( skos:member skos:narrowerTransitive ) .


#################################################################
#    Scenario Knowledge Root
#################################################################

:ScenarioKnowledge rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Scenario Knowledge"@en ;
  skos:definition "Scenario Knowledge encompasses structured information and insights relevant to understanding and analyzing specific situations in time series data."@en .


#################################################################
#    Top-Level Categories
#################################################################

:Annotation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Annotation"@en ;
  skos:broader :ScenarioKnowledge ;
  skos:definition "Annotations are labels added to time series data to provide validated context or information for better understanding."@en .

:ContextualDescription rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Contextual Description"@en ;
  skos:broader :ScenarioKnowledge ;
  skos:definition "Contextual description provides background or situational details that enhance the understanding of time series data."@en .

:Event rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Event"@en ;
  skos:broader :ScenarioKnowledge ;
  skos:definition "A specific occurrence or incident."@en .

:ScenarioParameter rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Scenario Parameter"@en ;
  skos:broader :ScenarioKnowledge ;
  skos:definition "Scenario Parameters are variables related to specific scenarios."@en .


#################################################################
#    Annotation Hierarchy
#################################################################

:Label rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Label"@en ;
  skos:broader :Annotation ;
  skos:definition "Labels are identifiers or markers added to time series data to categorize or highlight specific elements or features."@en .

:Keyword rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Keyword"@en ;
  skos:broader :Annotation ;
  skos:definition "Free-form tag used for categorization, organization and indexing."@en .

:Code rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Code"@en ;
  skos:broader :Annotation ;
  skos:definition "Standardized code used for categorization, organization and indexing."@en .

:CalendarEntry rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Calendar Entry"@en ;
  skos:broader :Annotation ;
  skos:definition "Calendar entries such as holidays, maintenance days."@en .

:QualityAnnotation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Quality Annotation"@en ;
  skos:broader :Annotation ;
  skos:definition "Quality metadata associated with observations."@en .

:Involvement rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Involvement"@en ;
  skos:broader :Annotation ;
  skos:definition "Annotation describing participation or role of an actor or entity."@en .

:Location rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Location"@en ;
  skos:broader :Annotation ;
  skos:definition "Location associated with data, events, or entities."@en .

:Purpose rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Purpose"@en ;
  skos:broader :Annotation ;
  skos:definition "Purpose or motivation of an annotation."@en .


#################################################################
#    Contextual Description Hierarchy
#################################################################

:Note rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Note"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Notes are brief pieces of information that are added to time series data to highlight important aspects or observations."@en .

:InformalComment rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Informal Comment"@en ;
  skos:broader :Note ;
  skos:definition "An informal note which can literally be any arbitrary message that is not covered by a predefined category."@en .

:FormalDescription rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Formal Description"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Formal Description provides formally defined background or situational details that enhance the understanding of time series data."@en .

:Fact rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Fact"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Evaluated statement that holds true and equals ground truth information."@en .

:InferredFact rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Inferred Fact"@en ;
  skos:broader :Fact ;
  skos:definition "Fact derived through logical inference rather than direct observation."@en .

:Rule rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Rule"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Information which can be regarded a restriction or instruction."@en .

:AlarmRule rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Alarm Rule"@en ;
  skos:broader :Rule ;
  skos:definition "Rule defining alarm conditions and logic."@en .

:SchedulingPolicy rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Scheduling Policy"@en ;
  skos:broader :Rule ;
  skos:definition "Rule defining scheduling and dispatch policies."@en .

:Constraint rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Constraint"@en ;
  skos:broader :Rule ;
  skos:definition "Restriction or limitation governing system behavior or valid operating ranges."@en .

:OperationalConstraint rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Operational Constraint"@en ;
  skos:broader :Constraint ;
  skos:definition "Constraint derived from operational requirements or physical limitations."@en .

:TemporalConstraint rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Temporal Constraint"@en ;
  skos:broader :Constraint ;
  skos:definition "Constraint specifying timing requirements, durations, or sequencing rules."@en .

:Assumption rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Assumption"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Assumptions are hypotheses or premises considered within the context of analyzing time series data."@en .

:Hypothesis rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Hypothesis"@en ;
  skos:broader :Assumption ;
  skos:definition "Proposed explanation or prediction explicitly subject to verification or testing."@en .

:Documentation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Documentation"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Description of a procedure or process."@en .

:Guideline rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Guideline"@en ;
  skos:broader :Documentation ;
  skos:definition "Recommendation that helps to make decisions and ensures correct, consistent application."@en .

:WorkInstruction rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Work Instruction"@en ;
  skos:broader :Documentation ;
  skos:definition "Prescriptive step-by-step instructions."@en .

:ControlPlan rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Control Plan"@en ;
  skos:broader :Documentation ;
  skos:definition "Plan describing process controls and checks."@en .

:MaintenancePlan rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Maintenance Plan"@en ;
  skos:broader :Documentation ;
  skos:definition "Plan describing maintenance strategy and tasks."@en .

:SafetyProcedure rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Safety Procedure"@en ;
  skos:broader :Documentation ;
  skos:definition "Prescribed safety steps or protocols."@en .

:Plan rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Plan"@en ;
  skos:broader :Documentation ;
  skos:definition "Documented intended course of action specifying what should occur."@en .

:Schedule rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Schedule"@en ;
  skos:broader :Plan ;
  skos:definition "Time-based plan specifying when activities or states should occur."@en .

:Forecast rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Forecast"@en ;
  skos:broader :Plan ;
  skos:definition "Predicted future values, conditions, or events."@en .

:ProcessStep rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Process Step"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Process step context associated with an event (e.g., shipping, receiving) or transaction context (e.g., purchase orders, invoices)."@en .

:CausalFactor rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Causal Factor"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Description of a cause or influence relevant to a situation."@en .

:ExternalCondition rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "External Condition"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "External factor or condition outside the monitored system that influences observed behavior."@en .

:EnvironmentalCondition rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Environmental Condition"@en ;
  skos:broader :ExternalCondition ;
  skos:definition "Physical environmental factor such as temperature, humidity, or pressure affecting system behavior."@en .

:Relationship rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Relationship"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Known association or connection between entities, variables, or time series."@en .

:Dependency rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Dependency"@en ;
  skos:broader :Relationship ;
  skos:definition "Relationship indicating one entity or process depends on another."@en .

:Correlation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Correlation"@en ;
  skos:broader :Relationship ;
  skos:definition "Known co-occurrence or statistical association between variables."@en .

:Evidence rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Evidence"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Information or data supporting or refuting an assumption, hypothesis, or conclusion."@en .

:SupportingEvidence rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Supporting Evidence"@en ;
  skos:broader :Evidence ;
  skos:definition "Evidence that confirms or supports an assumption or hypothesis."@en .

:ContradictingEvidence rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Contradicting Evidence"@en ;
  skos:broader :Evidence ;
  skos:definition "Evidence that contradicts or refutes an assumption or hypothesis."@en .

:Justification rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Justification"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Reasoning or explanation supporting a decision, conclusion, or annotation."@en .

:ValidationOutcome rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Validation Outcome"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Result or conclusion of a validation or verification process."@en .

:Conclusion rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Conclusion"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Outcome or finding derived from analysis, reasoning, or validation."@en .

:Contradiction rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Contradiction"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Identified conflict or inconsistency between facts, assumptions, or observations."@en .

:Inference rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Inference"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Knowledge or conclusion derived through reasoning from other facts or observations."@en .

:Explanation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Explanation"@en ;
  skos:broader :ContextualDescription ;
  skos:definition "Descriptive account clarifying why or how something occurred."@en .


#################################################################
#    Formal Description / Math Expression Hierarchy
#################################################################

:MathExpression rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Math Expression"@en ;
  skos:broader :FormalDescription ;
  skos:definition "Math Expressions are mathematical formulas or equations used to model or analyze time series data."@en .

:BooleanEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Boolean Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Boolean Equations involve logical operators and logical expressions."@en .

:Condition rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Condition"@en ;
  skos:broader :BooleanEquation ;
  skos:definition "Boolean expressions used to evaluate conditions within time series data."@en .

:AlgebraicEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Algebraic Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Algebraic Equations are mathematical statements consisting of algebraic expressions used in the analysis of time series data."@en .

:DifferentialEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Differential Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Differential Equations involve derivatives and are used to model dynamic changes and trends in time series data."@en .

:PolynomialEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Polynomial Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Polynomial Equations consist of terms raised to powers, representing relationships and patterns within time series data."@en .

:ExponentialEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Exponential Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Exponential Equations model growth or decay processes in time series data using exponential functions."@en .

:LogarithmicEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Logarithmic Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Logarithmic Equations involve logarithms and are used to model multiplicative relationships in time series data."@en .

:TrigonometricEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Trigonometric Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Trigonometric Equations use trigonometric functions to represent periodic patterns and cycles in time series data."@en .

:IntegralEquation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Integral Equation"@en ;
  skos:broader :MathExpression ;
  skos:definition "Integral Equations involve integrals and are used to analyze cumulative effects and total values in time series data."@en .


#################################################################

#    Event Hierarchy

#################################################################

:CategorizedEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Categorized Event"@en ;
  skos:broader :Event ;
  skos:definition "An event that is predefined and not an unexpected observation."@en .

:UncategorizedEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Uncategorized Event"@en ;
  skos:broader :Event ;
  skos:definition "An event that is not predefined and thus an unexpected observation."@en .

:Observation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Observation"@en ;
  skos:broader :UncategorizedEvent ;
  skos:definition "Observations are specific perceptions made based on time series behaviors."@en .

:UncharacteristicObservation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Uncharacteristic Observation"@en ;
  skos:broader :Observation ;
  skos:definition "Observed irregularity."@en .


#################################################################
#    Categorized Event - Action Hierarchy
#################################################################

:Action rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Action"@en ;
  skos:broader :CategorizedEvent ;
  skos:definition "An action that equals a predefined event. Commonly performed to change or correct a certain process behavior."@en .

:Acknowledgment rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Acknowledgment"@en ;
  skos:broader :Action ;
  skos:definition "Acknowledgment of an event."@en .

:Confirmation rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Confirmation"@en ;
  skos:broader :Action ;
  skos:definition "Confirmation of previously unvalidated information."@en .

:ResetOrClear rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Reset or Clear"@en ;
  skos:broader :Action ;
  skos:definition "Action to clear or reset a condition or alarm state."@en .

:ParameterChange rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Parameter Change"@en ;
  skos:broader :Action ;
  skos:definition "Action/event indicating modification of one or more Scenario Parameters."@en .

:RecipeChangeEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Recipe Change Event"@en ;
  skos:broader :ParameterChange ;
  skos:definition "Parameter change affecting the process recipe configuration."@en .

:SetpointChange rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Setpoint Change"@en ;
  skos:broader :ParameterChange ;
  skos:definition "Parameter change affecting a control setpoint value."@en .

:ThresholdChange rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Threshold Change"@en ;
  skos:broader :ParameterChange ;
  skos:definition "Parameter change adjusting a threshold used in control, alarms, or logic."@en .

:SetupChangeover rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Setup Changeover"@en ;
  skos:broader :Action ;
  skos:definition "Action to switch equipment or operating setup between products or configurations."@en .

:BatchChangeover rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Batch Changeover"@en ;
  skos:broader :SetupChangeover ;
  skos:definition "Action to switch batches; a specialized form of setup changeover."@en .

:Reschedule rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Reschedule"@en ;
  skos:broader :Action ;
  skos:definition "Action altering planned timing or sequence of activities."@en .

:DispatchInstruction rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Dispatch Instruction"@en ;
  skos:broader :Action ;
  skos:definition "Instruction to assign or route work, orders, or tasks."@en .

:InspectionEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Inspection Event"@en ;
  skos:broader :Action ;
  skos:definition "Inspection or quality check activity."@en .

:ComplianceCheck rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Compliance Check"@en ;
  skos:broader :Action ;
  skos:definition "Action to verify compliance with rules or standards."@en .

:SimulationRun rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Simulation Run"@en ;
  skos:broader :Action ;
  skos:definition "Execution of a simulation."@en .

:Rejection rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Rejection"@en ;
  skos:broader :Action ;
  skos:definition "Action of rejecting or invalidating an assumption, hypothesis, or proposed information."@en .

:Approval rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Approval"@en ;
  skos:broader :Action ;
  skos:definition "Action of approving or accepting information, a plan, or a decision."@en .

:Revision rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Revision"@en ;
  skos:broader :Action ;
  skos:definition "Action of modifying or updating previous knowledge, assumptions, or annotations based on new information."@en .

:Retraction rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Retraction"@en ;
  skos:broader :Action ;
  skos:definition "Action of withdrawing previously asserted information or annotations."@en .


#################################################################
#    Categorized Event - Alert Hierarchy
#################################################################

:Alert rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Alert"@en ;
  skos:broader :CategorizedEvent ;
  skos:definition "User-facing notification about conditions or events affecting service or entities."@en .

:NonConformance rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Non-Conformance"@en ;
  skos:broader :Alert ;
  skos:definition "Notification that a product or process does not meet specification."@en .

:SafetyAlert rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Safety Alert"@en ;
  skos:broader :Alert ;
  skos:definition "Safety-related notification."@en .

:ThresholdBreach rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Threshold Breach"@en ;
  skos:broader :Alert ;
  skos:definition "Alert raised when a defined threshold is exceeded or violated."@en .


#################################################################
#    Categorized Event - Lifecycle Event Hierarchy
#################################################################

:LifecycleEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Lifecycle Event"@en ;
  skos:broader :CategorizedEvent ;
  skos:definition "Event marking activity lifecycle transitions such as start, complete, suspend, or resume."@en .

:CycleStart rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Cycle Start"@en ;
  skos:broader :LifecycleEvent ;
  skos:definition "Start of a repeating cycle or iteration."@en .

:ProductionCycleStart rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Production Cycle Start"@en ;
  skos:broader :CycleStart ;
  skos:definition "Start of a production cycle."@en .

:CycleComplete rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Cycle Complete"@en ;
  skos:broader :LifecycleEvent ;
  skos:definition "Completion of a repeating cycle or iteration."@en .

:ProductionCycleComplete rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Production Cycle Complete"@en ;
  skos:broader :CycleComplete ;
  skos:definition "Completion of a production cycle."@en .

:PhaseTransition rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Phase Transition"@en ;
  skos:broader :LifecycleEvent ;
  skos:definition "Transition from one operational phase or stage to another."@en .

:ModeChange rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Mode Change"@en ;
  skos:broader :LifecycleEvent ;
  skos:definition "Change in operating mode or state."@en .

:ShiftChange rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Shift Change"@en ;
  skos:broader :LifecycleEvent ;
  skos:definition "Transition between staff shifts."@en .


#################################################################
#    Categorized Event - Maintenance Event Hierarchy
#################################################################

:MaintenanceEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Maintenance Event"@en ;
  skos:broader :CategorizedEvent ;
  skos:definition "Event documenting scheduled or unscheduled maintenance activities for assets or devices."@en .

:PlannedDowntime rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Planned Downtime"@en ;
  skos:broader :MaintenanceEvent ;
  skos:definition "Scheduled outage or maintenance period."@en .

:UnplannedDowntime rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Unplanned Downtime"@en ;
  skos:broader :MaintenanceEvent ;
  skos:definition "Unscheduled outage or stop due to failure or other causes."@en .

:PreventiveMaintenanceEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Preventive Maintenance Event"@en ;
  skos:broader :MaintenanceEvent ;
  skos:definition "Planned maintenance performed to prevent failures."@en .

:CorrectiveMaintenanceEvent rdf:type owl:NamedIndividual, semts:KnowledgeConcept ;
  skos:prefLabel "Corrective Maintenance Event"@en ;
  skos:broader :MaintenanceEvent ;
